<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EU-CHEM INTEL — European Chemical Industry Intelligence Platform | Week 17–27 Apr 2026</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0b0f1a;
    --bg2:      #0f1421;
    --bg3:      #151c2e;
    --card:     #161d2f;
    --border:   #1e2a42;
    --border2:  #253047;
    --text:     #e2e8f0;
    --text2:    #94a3b8;
    --text3:    #64748b;
    --text4:    #475569;
    --cyan:     #22d3ee;
    --cyan2:    #67e8f9;
    --red:      #f87171;
    --amber:    #fbbf24;
    --green:    #34d399;
    --blue:     #60a5fa;
    --purple:   #a78bfa;
    --mono: 'IBM Plex Mono', 'Courier New', monospace;
    --sans: 'IBM Plex Sans', system-ui, sans-serif;
  }

  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--mono); overflow: hidden; }

  /* ── LAYOUT ── */
  #app { display: flex; height: 100vh; }

  /* ── SIDEBAR ── */
  #sidebar {
    width: 220px; min-width: 220px; background: var(--bg2);
    border-right: 1px solid var(--border); display: flex; flex-direction: column;
    transition: width .2s, min-width .2s;
  }
  #sidebar.collapsed { width: 52px; min-width: 52px; }

  .sidebar-logo { padding: 16px; border-bottom: 1px solid var(--border); }
  .logo-full .logo-title { color: var(--cyan); font-weight: 700; font-size: 13px; letter-spacing: .15em; }
  .logo-full .logo-sub   { color: var(--text3); font-size: 10px; letter-spacing: .15em; margin-top: 2px; }
  .logo-icon { color: var(--cyan); font-weight: 700; font-size: 11px; text-align: center; }
  #sidebar.collapsed .logo-full { display: none; }
  #sidebar:not(.collapsed) .logo-icon { display: none; }

  nav { flex: 1; padding: 8px; overflow-y: auto; }
  .nav-btn {
    display: flex; align-items: center; gap: 10px; width: 100%;
    padding: 8px 8px; border-radius: 6px; border: 1px solid transparent;
    background: none; color: var(--text3); font-family: var(--mono);
    font-size: 11px; font-weight: 500; letter-spacing: .04em;
    cursor: pointer; text-align: left; transition: all .15s; white-space: nowrap;
    margin-bottom: 2px;
  }
  .nav-btn:hover { color: var(--text); background: rgba(255,255,255,.04); }
  .nav-btn.active {
    background: rgba(34,211,238,.08); color: var(--cyan2);
    border-color: rgba(34,211,238,.2);
  }
  .nav-icon { font-size: 15px; flex-shrink: 0; width: 18px; text-align: center; }
  .nav-label { overflow: hidden; }
  #sidebar.collapsed .nav-label { display: none; }

  .sidebar-footer { padding: 10px; border-top: 1px solid var(--border); }
  #toggle-btn {
    width: 100%; background: none; border: none; color: var(--text4);
    font-family: var(--mono); font-size: 11px; cursor: pointer; padding: 4px;
    transition: color .15s;
  }
  #toggle-btn:hover { color: var(--text2); }

  /* ── MAIN ── */
  #main { flex: 1; display: flex; flex-direction: column; min-width: 0; }

  #topbar {
    background: rgba(15,20,33,.9); border-bottom: 1px solid var(--border);
    padding: 10px 24px; display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0; backdrop-filter: blur(8px);
  }
  #page-title { color: var(--text); font-size: 13px; font-weight: 500; }
  .topbar-right { display: flex; align-items: center; gap: 16px; }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
  .live-label { color: var(--text2); font-size: 11px; display: flex; align-items: center; gap: 6px; }

  #content { flex: 1; overflow-y: auto; padding: 24px; }

  /* ── PAGES ── */
  .page { display: none; }
  .page.active { display: block; }

  /* ── BADGES ── */
  .badge {
    display: inline-block; font-size: 10px; font-family: var(--mono);
    padding: 2px 7px; border-radius: 4px; border: 1px solid; white-space: nowrap;
    font-weight: 500; letter-spacing: .04em;
  }
  .badge-red    { background: rgba(127,29,29,.5);  color: #fca5a5; border-color: rgba(185,28,28,.4); }
  .badge-amber  { background: rgba(120,53,15,.5);  color: #fcd34d; border-color: rgba(180,83,9,.4); }
  .badge-green  { background: rgba(6,78,59,.5);    color: #6ee7b7; border-color: rgba(4,120,87,.4); }
  .badge-blue   { background: rgba(30,58,138,.5);  color: #93c5fd; border-color: rgba(37,99,235,.4); }
  .badge-gray   { background: rgba(51,65,85,.6);   color: #cbd5e1; border-color: rgba(71,85,105,.5); }
  .badge-purple { background: rgba(88,28,135,.5);  color: #c4b5fd; border-color: rgba(124,58,237,.4); }

  /* ── CARDS ── */
  .card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
  }

  /* ── SECTION TITLE ── */
  .section-title { margin-bottom: 16px; }
  .section-title-row { display: flex; align-items: center; gap: 8px; }
  .section-bar { width: 3px; height: 20px; background: var(--cyan); border-radius: 2px; flex-shrink: 0; }
  .section-title h2 { color: var(--text); font-size: 15px; font-weight: 600; }
  .section-title p  { color: var(--text2); font-size: 12px; margin-top: 4px; padding-left: 11px; }

  /* ── GRIDS ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
  .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px; }
  .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
  .grid-3-1 { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 20px; }
  @media (max-width: 900px) {
    .grid-3, .grid-4, .grid-3-1 { grid-template-columns: 1fr 1fr; }
    .grid-2-1 { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
  }

  /* ── SPACING UTILS ── */
  .space-y > * + * { margin-top: 12px; }
  .space-y-lg > * + * { margin-top: 20px; }
  .mt-4 { margin-top: 16px; }
  .mt-3 { margin-top: 12px; }
  .mt-2 { margin-top: 8px; }
  .mt-1 { margin-top: 4px; }
  .mb-3 { margin-bottom: 12px; }
  .mb-2 { margin-bottom: 8px; }
  .gap-2 { gap: 8px; }

  /* ── HEADER BANNER ── */
  .page-header {
    border-radius: 8px; padding: 16px 20px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; border: 1px solid;
  }
  .page-header .label { font-size: 10px; font-family: var(--mono); letter-spacing: .15em; font-weight: 600; }
  .page-header h1 { font-size: 18px; font-weight: 600; color: var(--text); margin-top: 3px; font-family: var(--sans); }
  .page-header-cyan  { background: linear-gradient(135deg, rgba(14,116,144,.2), rgba(21,28,46,.4)); border-color: rgba(14,116,144,.3); }
  .page-header-amber { background: linear-gradient(135deg, rgba(120,53,15,.2), rgba(21,28,46,.4)); border-color: rgba(180,83,9,.3); }
  .page-header-blue  { background: linear-gradient(135deg, rgba(30,58,138,.2), rgba(21,28,46,.4)); border-color: rgba(37,99,235,.3); }
  .page-header-green { background: linear-gradient(135deg, rgba(6,78,59,.2),  rgba(21,28,46,.4)); border-color: rgba(4,120,87,.3); }
  .page-header-purple{ background: linear-gradient(135deg, rgba(88,28,135,.2),rgba(21,28,46,.4)); border-color: rgba(109,40,217,.3); }
  .page-header-orange{ background: linear-gradient(135deg, rgba(124,45,18,.2),rgba(21,28,46,.4)); border-color: rgba(194,65,12,.3); }
  .page-header-slate { background: linear-gradient(135deg, rgba(51,65,85,.2), rgba(21,28,46,.4)); border-color: rgba(71,85,105,.3); }

  /* ── SIGNAL CARDS ── */
  .signal-card { padding: 16px; }
  .signal-card .s-label { color: var(--text3); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; }
  .signal-card .s-value { color: var(--text); font-size: 24px; font-weight: 700; margin-top: 4px; font-family: var(--sans); }
  .signal-card .s-badge { margin-top: 8px; }

  /* ── NEWS CARD ── */
  .news-item { padding: 12px; display: flex; gap: 12px; align-items: flex-start; }
  .news-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
  .news-meta { display: flex; gap: 8px; align-items: center; margin-bottom: 4px; flex-wrap: wrap; }
  .news-date { color: var(--text4); font-size: 10px; }
  .news-headline { color: #cbd5e1; font-size: 12px; line-height: 1.5; font-family: var(--sans); }

  /* ── ALERT CARD ── */
  .alert-item { padding: 12px 14px; }
  .alert-row { display: flex; justify-content: space-between; align-items: center; }
  .alert-name { color: var(--text); font-size: 13px; font-weight: 500; font-family: var(--sans); }
  .alert-status { color: var(--text3); font-size: 11px; margin-top: 4px; }

  /* ── METRIC CARD ── */
  .metric-card { padding: 12px; }
  .metric-label { color: var(--text3); font-size: 10px; }
  .metric-val { color: var(--text); font-size: 15px; font-weight: 600; margin-top: 3px; font-family: var(--sans); display: flex; align-items: center; gap: 5px; }
  .trend-up   { color: var(--red);   font-size: 11px; }
  .trend-down { color: var(--green); font-size: 11px; }

  /* ── TAB BAR ── */
  .tab-bar { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .tab-btn {
    padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 500;
    font-family: var(--mono); cursor: pointer; transition: all .15s;
    background: none; border: 1px solid var(--border2); color: var(--text2);
  }
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { background: rgba(34,211,238,.1); color: var(--cyan2); border-color: rgba(34,211,238,.3); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── FEED CARD ── */
  .feed-card { padding: 20px; }
  .feed-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 8px; }
  .feed-headline { color: var(--text); font-size: 14px; font-weight: 600; font-family: var(--sans); line-height: 1.4; margin-bottom: 8px; }
  .feed-body { color: var(--text2); font-size: 12px; line-height: 1.65; font-family: var(--sans); }
  .impl-list { margin-top: 12px; }
  .impl-label { color: var(--text4); font-size: 10px; letter-spacing: .1em; margin-bottom: 6px; }
  .impl-item { display: flex; gap: 8px; font-size: 12px; color: var(--text2); font-family: var(--sans); margin-bottom: 4px; }
  .impl-arrow { color: var(--cyan); flex-shrink: 0; }
  .source-row { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 8px; }
  .source-label { color: var(--text4); font-size: 10px; letter-spacing: .1em; }
  .source-link { color: var(--cyan); font-size: 11px; text-decoration: underline; text-underline-offset: 3px; word-break: break-all; }
  .source-link:hover { color: var(--cyan2); }

  /* ── BRIEF ── */
  .brief-card { padding: 24px; }
  .brief-label { color: var(--cyan); font-size: 10px; letter-spacing: .15em; margin-bottom: 12px; }
  .brief-title { color: var(--text); font-size: 17px; font-weight: 600; font-family: var(--sans); margin-bottom: 16px; }
  .brief-para { color: var(--text2); font-size: 13px; line-height: 1.7; font-family: var(--sans); margin-bottom: 16px; }
  .brief-block { border-left: 2px solid; padding-left: 14px; margin-bottom: 16px; }
  .brief-block.cyan-block  { border-color: rgba(34,211,238,.4); }
  .brief-block.red-block   { border-color: rgba(248,113,113,.4); }
  .brief-block.amber-block { border-color: rgba(251,191,36,.4); }
  .brief-block.blue-block  { border-color: rgba(96,165,250,.4); }
  .brief-block-title { color: var(--text); font-size: 13px; font-weight: 600; font-family: var(--sans); margin-bottom: 6px; }
  .brief-block-body  { color: var(--text2); font-size: 12px; line-height: 1.65; font-family: var(--sans); }
  .watch-box { background: rgba(30,42,66,.5); border: 1px solid var(--border2); border-radius: 6px; padding: 12px 14px; margin-top: 16px; }
  .watch-title { color: var(--text); font-size: 12px; font-weight: 600; font-family: var(--sans); margin-bottom: 8px; }
  .watch-item { display: flex; gap: 8px; font-size: 12px; color: var(--text2); font-family: var(--sans); margin-bottom: 5px; }

  /* ── ACTION TRACKER ── */
  .action-card { padding: 16px; }
  .action-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
  .action-title { color: var(--text); font-size: 13px; font-weight: 500; font-family: var(--sans); }
  .action-rationale { color: var(--text3); font-size: 11px; margin-top: 5px; font-family: var(--sans); }

  /* ── REGULATION ── */
  .reg-selector { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .reg-btn {
    padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 500;
    font-family: var(--mono); cursor: pointer; transition: all .15s;
    background: none; border: 1px solid var(--border2); color: var(--text2);
  }
  .reg-btn:hover { color: var(--text); }
  .reg-btn.active { background: rgba(251,191,36,.1); color: #fcd34d; border-color: rgba(251,191,36,.3); }
  .reg-detail { display: none; }
  .reg-detail.active { display: block; }
  .reg-overview { padding: 20px; }
  .reg-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .reg-name { color: var(--text); font-size: 15px; font-weight: 600; font-family: var(--sans); }
  .reg-body { color: var(--text2); font-size: 12px; line-height: 1.65; font-family: var(--sans); }
  .timeline { padding: 16px; }
  .tl-label { color: var(--text3); font-size: 10px; letter-spacing: .1em; margin-bottom: 14px; }
  .tl-item { display: flex; gap: 12px; margin-bottom: 0; }
  .tl-track { display: flex; flex-direction: column; align-items: center; }
  .tl-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
  .tl-dot.milestone { background: var(--cyan); }
  .tl-dot.current   { background: var(--amber); }
  .tl-dot.process   { background: #475569; }
  .tl-dot.future    { background: #334155; border: 1px solid #475569; }
  .tl-line { width: 1px; flex: 1; background: var(--border2); margin-top: 2px; min-height: 20px; }
  .tl-content { padding-bottom: 14px; }
  .tl-date { font-size: 10px; font-family: var(--mono); }
  .tl-date.milestone { color: var(--cyan); }
  .tl-date.current   { color: var(--amber); }
  .tl-date.process, .tl-date.future { color: var(--text4); }
  .tl-text { color: var(--text2); font-size: 12px; font-family: var(--sans); margin-top: 2px; line-height: 1.5; }
  .substance-list { padding: 16px; }
  .substance-item { background: rgba(30,42,66,.6); border: 1px solid var(--border); border-radius: 4px; padding: 6px 10px; font-size: 11px; color: var(--text2); font-family: var(--sans); margin-bottom: 6px; }
  .impl-section { padding: 16px; }

  /* ── COMPANY RADAR ── */
  .company-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 16px; }
  @media(max-width:700px) { .company-grid { grid-template-columns: 1fr 1fr; } }
  .company-btn {
    text-align: left; padding: 12px; border-radius: 8px;
    background: var(--card); border: 1px solid var(--border);
    cursor: pointer; transition: all .15s;
  }
  .company-btn:hover { border-color: var(--border2); }
  .company-btn.active { background: rgba(30,58,138,.2); border-color: rgba(37,99,235,.4); }
  .co-name { color: var(--text); font-size: 13px; font-weight: 600; font-family: var(--sans); }
  .co-country { color: var(--text3); font-size: 11px; margin-top: 2px; }
  .co-signal { margin-top: 8px; }
  .company-detail { display: none; }
  .company-detail.active { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }
  @media(max-width:800px) { .company-detail.active { grid-template-columns: 1fr; } }
  .dev-item { display: flex; gap: 12px; margin-bottom: 14px; align-items: flex-start; }
  .dev-type { flex-shrink: 0; }
  .dev-date { color: var(--text4); font-size: 10px; }
  .dev-text { color: var(--text2); font-size: 12px; font-family: var(--sans); margin-top: 3px; line-height: 1.5; }

  /* ── TABLE ── */
  .intel-table { width: 100%; border-collapse: collapse; }
  .intel-table tr { border-bottom: 1px solid var(--border); transition: background .1s; }
  .intel-table tr:hover { background: rgba(255,255,255,.02); }
  .intel-table td { padding: 12px 14px; vertical-align: top; }
  .td-title { color: var(--text); font-size: 12px; font-weight: 500; font-family: var(--sans); line-height: 1.4; }
  .td-meta { color: var(--text3); font-size: 11px; margin-top: 4px; display: flex; gap: 10px; flex-wrap: wrap; font-family: var(--sans); }
  .td-date { color: var(--text4); font-size: 11px; white-space: nowrap; }

  /* ── DB FILTER ── */
  .db-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .db-btn {
    padding: 5px 12px; border-radius: 5px; font-size: 11px; font-weight: 500;
    font-family: var(--mono); cursor: pointer; transition: all .15s;
    background: none; border: 1px solid var(--border2); color: var(--text3);
  }
  .db-btn:hover { color: var(--text); }
  .db-btn.active { background: rgba(51,65,85,.8); color: var(--text); border-color: #475569; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #1e2a42; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #253047; }

  /* ── MISC ── */
  .text-cyan  { color: var(--cyan);   }
  .text-red   { color: var(--red);    }
  .text-amber { color: var(--amber);  }
  .text-green { color: var(--green);  }
  .text-blue  { color: var(--blue);   }
  .text-muted { color: var(--text3);  }
  .text-dim   { color: var(--text4);  }
  .font-sans  { font-family: var(--sans); }
  .font-mono  { font-family: var(--mono); }
  .fw-600 { font-weight: 600; }
  .separator { border: none; border-top: 1px solid var(--border); margin: 12px 0; }
  .flex { display: flex; }
  .flex-wrap { flex-wrap: wrap; }
  .items-center { align-items: center; }
  .items-start  { align-items: flex-start; }
  .justify-between { justify-content: space-between; }
  .gap-8  { gap: 8px; }
  .gap-12 { gap: 12px; }
  .small  { font-size: 11px; }
  .xs     { font-size: 10px; letter-spacing:.06em; }
  .summary-text { color: var(--text2); font-size: 12px; font-family: var(--sans); line-height: 1.65; }

  /* caution signal */
  .signal-caution { color: var(--red); font-size: 22px; font-weight: 700; font-family: var(--sans); }
</style>
</head>
<body>
<div id="app">

  <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
  <div id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-full">
        <div class="logo-title">EU-CHEM</div>
        <div class="logo-sub">INTEL PLATFORM</div>
      </div>
      <div class="logo-icon">EC</div>
    </div>
    <nav id="nav">
      <button class="nav-btn active" data-page="dashboard"><span class="nav-icon">▪</span><span class="nav-label">Dashboard</span></button>
      <button class="nav-btn" data-page="weekly"><span class="nav-icon">📋</span><span class="nav-label">Weekly Intelligence</span></button>
      <button class="nav-btn" data-page="regulation"><span class="nav-icon">⚖️</span><span class="nav-label">Regulation Monitor</span></button>
      <button class="nav-btn" data-page="company"><span class="nav-icon">🏭</span><span class="nav-label">Company Radar</span></button>
      <button class="nav-btn" data-page="capacity"><span class="nav-icon">📊</span><span class="nav-label">Capacity Tracker</span></button>
      <button class="nav-btn" data-page="technology"><span class="nav-icon">🔬</span><span class="nav-label">Technology Radar</span></button>
      <button class="nav-btn" data-page="market"><span class="nav-icon">📈</span><span class="nav-label">Market Signals</span></button>
      <button class="nav-btn" data-page="database"><span class="nav-icon">🗄️</span><span class="nav-label">Intelligence Database</span></button>
    </nav>
    <div class="sidebar-footer">
      <button id="toggle-btn">← Collapse</button>
    </div>
